<%
  style = `
  <style>
    .profile-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  </style>
  `;
%>

<div class="profile-shell">
  <div class="hero-panel mb-4">
    <div class="row align-items-end">
      <div class="col-lg-8">
        <div class="section-kicker mb-2">Account Center</div>
        <h1 class="mb-3">我的資料與驗證狀態</h1>
        <p class="mb-0">在這裡維護聯絡資料、Email 驗證狀態與個人帳號資訊，讓報價與通知流程保持正確。</p>
      </div>
      <div class="col-lg-4 mt-3 mt-lg-0 text-lg-right">
        <a class="btn btn-light mr-2" href="/dashboard">返回儀表板</a>
        <a class="btn btn-outline-light" href="/quotes">查看報價單</a>
      </div>
    </div>
  </div>

  <div id="msgBox" class="alert" style="display:none;"></div>

  <div class="profile-grid">
    <div class="profile-side">
      <div class="data-card">
        <div class="section-kicker">Profile Summary</div>
        <div class="section-title mb-3">帳號摘要</div>
        <div class="profile-badge" id="pType">載入中</div>
        <div class="profile-meta mt-3">
          <div class="profile-meta-item">
            <div class="profile-meta-label">帳號</div>
            <div class="profile-meta-value auth-mono" id="pAccount"></div>
          </div>
          <div class="profile-meta-item">
            <div class="profile-meta-label">建立時間</div>
            <div class="profile-meta-value" id="pCreate"></div>
          </div>
          <div class="profile-meta-item">
            <div class="profile-meta-label">最後更新</div>
            <div class="profile-meta-value" id="pUpdate"></div>
          </div>
        </div>
      </div>

      <div class="data-card">
        <div class="section-kicker">Verification</div>
        <div class="section-title mb-3">Email 驗證狀態</div>
        <div class="form-group mb-2">
          <label>待驗證 Email</label>
          <input id="pPendingEmail" class="form-control" disabled placeholder="目前沒有待驗證 Email">
        </div>
        <div id="pendingHint" class="form-note mb-3"></div>
        <div id="pendingActions" style="display:none;">
          <button id="btnResendVerify" class="btn btn-outline-primary btn-sm" onclick="resendVerifyEmail()">重新寄送驗證信</button>
          <div class="form-note mt-2">若未收到信件，請先確認垃圾郵件匣。</div>
        </div>
      </div>
    </div>

    <div class="data-card">
      <div class="section-kicker">Editable Fields</div>
      <div class="section-title mb-3">可更新資料</div>

      <div class="form-row">
        <div class="form-group col-md-6">
          <label for="pName">姓名</label>
          <input id="pName" class="form-control" maxlength="50" placeholder="請輸入姓名">
          <div class="form-note mt-1">最多 50 個字元。</div>
        </div>
        <div class="form-group col-md-6">
          <label for="pCell">手機</label>
          <input id="pCell" class="form-control" maxlength="15" placeholder="例如 09xxxxxxxx">
          <div class="form-note mt-1">手機為必填欄位。</div>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group col-md-6">
          <label for="pEmail">Email</label>
          <input id="pEmail" class="form-control" maxlength="200" placeholder="例如 name@example.com">
          <div id="emailHint" class="form-note mt-1">Email 規則載入中…</div>
        </div>
        <div class="form-group col-md-6">
          <label for="pEmail2">再次輸入 Email</label>
          <input id="pEmail2" class="form-control" maxlength="200" placeholder="請再次輸入 Email 進行確認">
          <div class="form-note mt-1">兩次輸入必須一致，避免通知寄錯。</div>
        </div>
      </div>

      <div class="profile-actions mt-3">
        <button id="btnSave" class="btn btn-primary" onclick="saveProfile()">儲存變更</button>
        <button class="btn btn-outline-secondary" type="button" onclick="loadMe()">重新載入</button>
      </div>
    </div>
  </div>
</div>

<script>
  let securityCfg = {
    ACCOUNT_MIN: 3,
    ACCOUNT_MAX: 32,
    EMAIL_MAX: 200,
    PWD_MIN: 10,
    PWD_MAX: 72,
  };

  let me = null;

  function showMsg(msg, type = 'danger', autoHideMs = 0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showError(msg) { showMsg(msg, 'danger'); }
  function showSuccess(msg) { showMsg(msg, 'success', 900); }
  function clearMsg() {
    const box = document.getElementById('msgBox');
    box.style.display = 'none';
    box.innerText = '';
  }

  function getApiErrorMessage(err, fallback = '操作失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function apiRequest(method, url, data) {
    try {
      const res = await axios({ method, url, data });
      return res.data;
    } catch (err) {
      const msg = getApiErrorMessage(err);
      console.error('[API ERROR]', { method, url, msg, data, err, response: err?.response?.data });
      showError(msg);
      throw err;
    }
  }

  function applySecurityConfigToUI() {
    const emailHint = document.getElementById('emailHint');
    if (emailHint) {
      emailHint.innerText = `Email 最長 ${securityCfg.EMAIL_MAX} 字元，需為合法 Email 格式。`;
    }
  }

  async function loadSecurityConfig() {
    try {
      const data = await apiRequest('get', '/api/security/config');
      securityCfg = {
        ACCOUNT_MIN: Number(data.ACCOUNT_MIN) || securityCfg.ACCOUNT_MIN,
        ACCOUNT_MAX: Number(data.ACCOUNT_MAX) || securityCfg.ACCOUNT_MAX,
        EMAIL_MAX: Number(data.EMAIL_MAX) || securityCfg.EMAIL_MAX,
        PWD_MIN: Number(data.PWD_MIN) || securityCfg.PWD_MIN,
        PWD_MAX: Number(data.PWD_MAX) || securityCfg.PWD_MAX,
      };
    } catch (_) {
      console.warn('[security/config] fallback to defaults');
    } finally {
      applySecurityConfigToUI();
    }
  }

  function renderPending(pendingEmail) {
    const p = document.getElementById('pPendingEmail');
    const hint = document.getElementById('pendingHint');
    const actions = document.getElementById('pendingActions');

    if (!pendingEmail) {
      p.value = '';
      p.placeholder = '目前沒有待驗證 Email';
      hint.innerText = '';
      if (actions) actions.style.display = 'none';
      return;
    }

    p.value = pendingEmail.email || '';
    hint.innerText = `待驗證有效期限：${pendingEmail.expires_at || ''}`;
    if (actions) actions.style.display = 'block';
  }

  async function loadMe() {
    const data = await apiRequest('get', '/api/me/profile');
    me = data.user;

    document.getElementById('pAccount').innerText = me.account || '';
    document.getElementById('pName').value = me.name || '';
    document.getElementById('pCell').value = me.cellphone || '';
    document.getElementById('pEmail').value = me.email || '';
    document.getElementById('pEmail2').value = me.email || '';
    document.getElementById('pType').innerText = me.type || '一般帳號';
    document.getElementById('pCreate').innerText = me.create_date || '';
    document.getElementById('pUpdate').innerText = me.update_date || '';

    renderPending(data.pendingEmail);
  }

  async function saveProfile() {
    const btn = document.getElementById('btnSave');
    btn.disabled = true;
    clearMsg();

    try {
      const name = document.getElementById('pName').value.trim();
      const cellphone = document.getElementById('pCell').value.trim();
      const email = document.getElementById('pEmail').value.trim();
      const email2 = document.getElementById('pEmail2').value.trim();

      if (!cellphone) { showError('手機為必填'); return; }
      if (!email) { showError('Email 為必填'); return; }
      if (email !== email2) { showError('兩次輸入的 Email 不一致'); return; }

      const res = await apiRequest('patch', '/api/me/profile', { name, cellphone, email });

      if (res.status === 'pending') {
        showMsg(res.message || '已寄出驗證信，請完成驗證後才會生效。', 'info', 1200);
      } else {
        showSuccess('已更新個人資料');
      }

      await loadMe();
    } finally {
      btn.disabled = false;
    }
  }

  async function resendVerifyEmail() {
    const btn = document.getElementById('btnResendVerify');
    if (btn) btn.disabled = true;

    try {
      const res = await apiRequest('post', '/api/me/email/resend');
      if (res.status === 'success') {
        showSuccess(res.message || '已重新寄送驗證信');
      } else {
        showMsg(res.message || '處理完成，請檢查信箱。', 'info', 1200);
      }
      await loadMe();
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  function checkEmailVerifiedFlag() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('verified') === '1') {
      showSuccess('Email 已驗證');
      setTimeout(() => {
        const url = new URL(window.location.href);
        url.searchParams.delete('verified');
        window.history.replaceState({}, '', url.pathname);
      }, 900);
    }
  }

  $(document).ready(() => {
    Promise.all([loadSecurityConfig(), loadMe()]).then(() => {
      checkEmailVerifiedFlag();
    }).catch(() => {
      alert('權限不足或系統錯誤');
      location.href = '/login';
    });
  });
</script>
