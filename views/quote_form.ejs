<div class="container-fluid">
  <div class="platform-shell p-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4">
      <div>
        <div class="section-kicker">Quote Detail</div>
        <div class="section-title"><%= mode === 'create' ? '新增遊戲檢測報價單' : '編輯報價單與案件狀態' %></div>
      </div>
      <div class="mt-3 mt-lg-0">
        <a class="btn btn-outline-secondary" href="/quotes">返回列表</a>
      </div>
    </div>

    <div id="msgBox" class="alert d-none"></div>

    <div class="row">
      <div class="col-xl-8 mb-4">
        <div class="form-card h-100">
          <div class="form-row">
            <div class="form-group col-md-4">
              <label for="quoteDate">報價日期</label>
              <input id="quoteDate" type="date" class="form-control">
            </div>
            <div class="form-group col-md-4">
              <label for="customerOrderNo">客戶訂單編號</label>
              <input id="customerOrderNo" class="form-control">
            </div>
            <div class="form-group col-md-4">
              <label for="internalOrderNo">內部訂單編號</label>
              <input id="internalOrderNo" class="form-control">
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-4">
              <label for="customerName">客戶名稱</label>
              <input id="customerName" class="form-control">
            </div>
            <div class="form-group col-md-8">
              <label for="gameTitle">申購內容 / 遊戲名稱</label>
              <input id="gameTitle" class="form-control">
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-4">
              <label for="serviceName">服務項目</label>
              <input id="serviceName" class="form-control" value="APP檢測服務(IP流向檢測)">
            </div>
            <div class="form-group col-md-2">
              <label for="quantity">數量</label>
              <input id="quantity" type="number" min="1" class="form-control" value="1">
            </div>
            <div class="form-group col-md-3">
              <label for="unitPriceUntaxed">單價(未稅)</label>
              <input id="unitPriceUntaxed" type="number" min="0" class="form-control" value="0">
            </div>
            <div class="form-group col-md-3">
              <label for="totalUntaxed">總計(未稅)</label>
              <input id="totalUntaxed" type="number" min="0" class="form-control" value="0">
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-6">
              <label>檢測平台</label>
              <div class="border rounded p-3">
                <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="platformIos"><label class="form-check-label" for="platformIos">iOS</label></div>
                <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="platformAndroid"><label class="form-check-label" for="platformAndroid">Android</label></div>
                <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="platformWeb"><label class="form-check-label" for="platformWeb">Web</label></div>
                <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="platformOther"><label class="form-check-label" for="platformOther">Other</label></div>
              </div>
            </div>
            <div class="form-group col-md-3">
              <label for="signedAt">客戶回簽日期</label>
              <input id="signedAt" type="date" class="form-control">
            </div>
            <div class="form-group col-md-3">
              <label for="closedAt">結案日期</label>
              <input id="closedAt" type="date" class="form-control">
            </div>
          </div>

          <div class="form-group">
            <label for="notes">備註</label>
            <textarea id="notes" rows="4" class="form-control"></textarea>
          </div>
        </div>
      </div>

      <div class="col-xl-4 mb-4">
        <div class="form-card h-100">
          <div class="form-group">
            <label for="caseStatus">案件狀態</label>
            <select id="caseStatus" class="form-control">
              <option>DRAFT</option>
              <option>QUOTED</option>
              <option>SIGNED</option>
              <option>IN_PROGRESS</option>
              <option>COMPLETED</option>
              <option>CLOSED</option>
            </select>
          </div>
          <div class="form-group">
            <label for="billingStatus">請款狀態</label>
            <select id="billingStatus" class="form-control">
              <option>UNBILLED</option>
              <option>BILLED</option>
              <option>SETTLED</option>
            </select>
          </div>
          <div class="form-note mb-3">建立後可在案件追蹤頁快速更新狀態；這裡則適合編修完整資料。</div>
          <button class="btn btn-danger btn-block mb-2" onclick="saveQuote()"><%= mode === 'create' ? '建立報價單' : '儲存變更' %></button>
          <a class="btn btn-outline-secondary btn-block" href="/cases">前往案件追蹤</a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const quoteId = <%- JSON.stringify(quoteId) %>;
  const mode = <%- JSON.stringify(mode) %>;

  function showMsg(message, type = 'danger') {
    const box = document.getElementById('msgBox');
    box.className = `alert alert-${type}`;
    box.textContent = message;
  }

  function collectPayload() {
    return {
      quoteDate: document.getElementById('quoteDate').value,
      customerOrderNo: document.getElementById('customerOrderNo').value,
      customerName: document.getElementById('customerName').value,
      gameTitle: document.getElementById('gameTitle').value,
      serviceName: document.getElementById('serviceName').value,
      internalOrderNo: document.getElementById('internalOrderNo').value,
      quantity: Number(document.getElementById('quantity').value || 1),
      unitPriceUntaxed: Number(document.getElementById('unitPriceUntaxed').value || 0),
      totalUntaxed: Number(document.getElementById('totalUntaxed').value || 0),
      signedAt: document.getElementById('signedAt').value || null,
      closedAt: document.getElementById('closedAt').value || null,
      caseStatus: document.getElementById('caseStatus').value,
      billingStatus: document.getElementById('billingStatus').value,
      notes: document.getElementById('notes').value,
      platforms: {
        ios: document.getElementById('platformIos').checked,
        android: document.getElementById('platformAndroid').checked,
        web: document.getElementById('platformWeb').checked,
        other: document.getElementById('platformOther').checked,
      },
    };
  }

  function fillForm(quote) {
    document.getElementById('quoteDate').value = quote.quoteDate || '';
    document.getElementById('customerOrderNo').value = quote.customerOrderNo || '';
    document.getElementById('customerName').value = quote.customerName || '';
    document.getElementById('gameTitle').value = quote.gameTitle || '';
    document.getElementById('serviceName').value = quote.serviceName || '';
    document.getElementById('internalOrderNo').value = quote.internalOrderNo || '';
    document.getElementById('quantity').value = quote.quantity || 1;
    document.getElementById('unitPriceUntaxed').value = quote.unitPriceUntaxed || 0;
    document.getElementById('totalUntaxed').value = quote.totalUntaxed || 0;
    document.getElementById('signedAt').value = quote.signedAt || '';
    document.getElementById('closedAt').value = quote.closedAt || '';
    document.getElementById('caseStatus').value = quote.caseStatus || 'QUOTED';
    document.getElementById('billingStatus').value = quote.billingStatus || 'UNBILLED';
    document.getElementById('notes').value = quote.notes || '';
    document.getElementById('platformIos').checked = !!quote.platforms?.ios;
    document.getElementById('platformAndroid').checked = !!quote.platforms?.android;
    document.getElementById('platformWeb').checked = !!quote.platforms?.web;
    document.getElementById('platformOther').checked = !!quote.platforms?.other;
  }

  function recalcTotal() {
    const qty = Number(document.getElementById('quantity').value || 0);
    const price = Number(document.getElementById('unitPriceUntaxed').value || 0);
    document.getElementById('totalUntaxed').value = qty * price;
  }

  async function loadQuote() {
    if (!quoteId) {
      document.getElementById('quoteDate').value = new Date().toISOString().slice(0, 10);
      return;
    }

    try {
      const response = await axios.get(`/api/quotes/${quoteId}`);
      fillForm(response.data.quote);
    } catch (error) {
      showMsg(error?.response?.data?.message || '讀取報價資料失敗');
    }
  }

  async function saveQuote() {
    const payload = collectPayload();
    try {
      if (mode === 'create') {
        const response = await axios.post('/api/quotes', payload);
        window.location.href = `/quotes/${response.data.quote.id}`;
      } else {
        await axios.patch(`/api/quotes/${quoteId}`, payload);
        showMsg('報價單已更新', 'success');
      }
    } catch (error) {
      showMsg(error?.response?.data?.message || '儲存失敗');
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.getElementById('quantity').addEventListener('input', recalcTotal);
    document.getElementById('unitPriceUntaxed').addEventListener('input', recalcTotal);
    loadQuote();
  });
</script>
