 <%- include('./basic/auth_card.ejs', {
  authWrapClass: '',
  titleText: 'Email ж’ҪоӨң?',
  subtitleText: 'з”Ү?оҜӯж’ҪоӨң??еҮҪ???Emailеҡ—п—Ҫ?иқ”пҡ—ВҖо©җВҖ?,
  body: `
    <div id="subtitle" class="small-muted mb-3">ж’ҪоӨң?йҠқе“Ё?йҡўп•ҹ??о©җВҖ?/div>

    <div class="text-center mt-3">
      <a class="btn btn-outline-secondary" href="/profile">?оөҘ??п„•???/a>
      <a class="btn btn-outline-secondary ml-2" href="/dashboard">?оөЁ???/a>
    </div>

    <div class="small-muted mt-3 text-center">
      ж’ҪоӨң??о“Һ?ж•әп—»??иҠё?й қе–і??п—»??п„•??о©‘ВҖпҡ•ВҖ?    </div>
  `
}) %>

<script>
  function showMsg(msg, type='danger', autoHideMs=0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger','alert-success','alert-warning','alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showSuccess(msg) { showMsg(msg, 'success', 800); }
  function showInfo(msg) { showMsg(msg, 'info'); }
  function showError(msg) { showMsg(msg, 'danger'); }

  function setSubtitle(text) {
    const el = document.getElementById('subtitle');
    if (el) el.innerText = text || '';
  }

  function getApiErrorMessage(err, fallback='ж’ҪоӨң?жҶӯжңӣ?') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function runVerify() {
    const params = new URLSearchParams(location.search);
    const token = params.get('token') || '';

    if (!token) {
      setSubtitle('иқ»з®Ҹ? tokenеҡ—п—Ҫ?иқЈз®„?????иҮ¬о’Ҹж‘°п—»оһ®');
      showError('иқ»з®Ҹ? tokenеҡ—п—Ҫ?иқЈз®„?????иҮ¬о’Ҹж‘°п—»оһ®');
      return;
    }

    try {
      setSubtitle('ж’ҪоӨң?йҠқе“Ё?йҡўп•ҹ??о©җВҖ?);
      showInfo('ж’ҪоӨң?йҠқеҮҢВҖ?);

      await axios.get('/api/me/email/verify', { params: { token } });

      setSubtitle('ж’ҪоӨң??о“Һ?еҡ—п—»иҝӨ?еҲ»жӯІ?оөўВҖп—»??п„•??о©‘ВҖпҡ”ВҖ?);
      showSuccess('ж’ҪоӨң??о“Һ?еҡ—оәҪmail ж’Ңи„«оӯң??);

      setTimeout(() => {
        window.location.href = '/profile?verified=1';
      }, 800);

    } catch (e) {
      console.error(e);
      setSubtitle('ж’ҪоӨң?жҶӯжңӣ?');
      showError(getApiErrorMessage(e, 'ж’ҪоӨң?жҶӯжңӣ??оўҖВҖ??ж’Ңи„Јд»ғ??));
    }
  }

  $(document).ready(runVerify);
</script>
