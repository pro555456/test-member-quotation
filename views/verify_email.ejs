<%- include('./basic/auth_card.ejs', {
  authWrapClass: '',
  titleText: 'Email 驗證',
  subtitleText: '系統正在驗證你的 Email，完成後會自動導回個人資料頁。',
  body: `
    <div id="subtitle" class="small-muted mb-3">請稍候，系統正在驗證中。</div>

    <div class="text-center mt-3">
      <a class="btn btn-outline-secondary" href="/profile">返回我的資料</a>
      <a class="btn btn-outline-secondary ml-2" href="/dashboard">返回儀表板</a>
    </div>

    <div class="small-muted mt-3 text-center">
      若驗證失敗，請稍後重試，或重新申請驗證信。
    </div>
  `
}) %>

<script>
  function showMsg(msg, type = 'danger', autoHideMs = 0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showSuccess(msg) { showMsg(msg, 'success', 1000); }
  function showInfo(msg) { showMsg(msg, 'info'); }
  function showError(msg) { showMsg(msg, 'danger'); }

  function setSubtitle(text) {
    const el = document.getElementById('subtitle');
    if (el) el.innerText = text || '';
  }

  function getApiErrorMessage(err, fallback = 'Email 驗證失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function runVerify() {
    const params = new URLSearchParams(location.search);
    const token = params.get('token') || '';

    if (!token) {
      setSubtitle('缺少驗證 token，無法進行 Email 驗證。');
      showError('缺少驗證 token，無法進行 Email 驗證。');
      return;
    }

    try {
      setSubtitle('系統正在驗證你的 Email，請稍候。');
      showInfo('驗證中…');

      await axios.get('/api/me/email/verify', { params: { token } });

      setSubtitle('Email 驗證完成，即將導回個人資料頁。');
      showSuccess('Email 驗證成功。');

      setTimeout(() => {
        window.location.href = '/profile?verified=1';
      }, 1000);
    } catch (error) {
      console.error(error);
      setSubtitle('Email 驗證失敗。');
      showError(getApiErrorMessage(error, 'Email 驗證失敗，請稍後再試。'));
    }
  }

  $(document).ready(runVerify);
</script>
