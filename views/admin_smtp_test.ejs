<!-- ✅ 4) 可選：把它加進 SMTP 測試頁（admin_smtp_test.ejs）
如果你要更方便，我可以順便幫你在 /admin/smtp-test 頁面加一個「檢查 SMTP 狀態」按鈕，直接把 dns/tcp 結果渲染出來（不用開 JSON）。
你回我一句「要加到 smtp-test 頁」我就直接吐整份可覆蓋版 admin_smtp_test.ejs（含狀態區塊）。 -->
<%
style = `
<style>
  .small-muted { font-size: 12px; color: #666; }
  textarea { resize: vertical; }

  .kv { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono","Courier New", monospace; }
  pre.kv-pre { white-space: pre-wrap; margin: 0; }
  .badge-soft { border: 1px solid rgba(0,0,0,.1); padding: .25rem .5rem; border-radius: 999px; font-size: 12px; }
</style>
`;
%>

<div class="container my-4" style="max-width: 980px;">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h3 class="text-danger m-0">SMTP 測試工具</h3>
      <div class="small-muted mt-1">部署到 Ubuntu/VM 時可快速定位：env 缺漏、DNS、TCP 連線（不發信）。</div>
    </div>
    <div>
      <a class="btn btn-outline-secondary btn-sm" href="/admin">回後臺</a>
    </div>
  </div>

  <!-- ✅ 統一 msgBox -->
  <div id="msgBox" class="alert mt-3" style="display:none;"></div>

  <!-- ✅ 狀態區塊 -->
  <div class="border rounded p-3 mt-3">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="m-0">SMTP 設定狀態</h5>
      <div>
        <button id="btnStatus" class="btn btn-outline-primary btn-sm" onclick="checkSmtpStatus()">檢查 SMTP 狀態</button>
      </div>
    </div>

    <div class="small-muted mt-2">
      會檢查：<b>.env 是否齊全</b>、<b>SMTP_HOST DNS 是否可解析</b>、<b>SMTP_PORT TCP 是否可連線</b>（不發信）。
    </div>

    <div id="statusSummary" class="mt-3" style="display:none;"></div>

    <div id="statusDetails" class="mt-3" style="display:none;">
      <div class="row">
        <div class="col-md-6 mb-3">
          <div class="border rounded p-2 h-100">
            <div class="d-flex justify-content-between align-items-center">
              <b>Env</b>
              <span id="envBadge" class="badge-soft">—</span>
            </div>
            <div class="small-muted mt-1">敏感欄位已遮罩（不回傳明文）。</div>
            <pre class="kv kv-pre mt-2" id="envPre"></pre>
            <div class="small-muted mt-2" id="missingPre"></div>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <div class="border rounded p-2 h-100">
            <div class="d-flex justify-content-between align-items-center">
              <b>DNS</b>
              <span id="dnsBadge" class="badge-soft">—</span>
            </div>
            <pre class="kv kv-pre mt-2" id="dnsPre"></pre>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <div class="border rounded p-2 h-100">
            <div class="d-flex justify-content-between align-items-center">
              <b>TCP</b>
              <span id="tcpBadge" class="badge-soft">—</span>
            </div>
            <pre class="kv kv-pre mt-2" id="tcpPre"></pre>
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <div class="border rounded p-2 h-100">
            <b>Tips</b>
            <ul class="mt-2 mb-0" id="tipsList"></ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ✅ 發信區塊 -->
  <div class="border rounded p-3 mt-3">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="m-0">發送測試信</h5>
      <div class="small-muted">只給具備 <code>user:manage</code> 權限者</div>
    </div>

    <div class="form-row mt-3">
      <div class="form-group col-md-6">
        <label>收件人（to）</label>
        <input id="to" class="form-control" placeholder="例：name@example.com">
        <div class="small-muted mt-1">留空則會寄給「目前登入者的 Email」。</div>
      </div>

      <div class="form-group col-md-6">
        <label>主旨</label>
        <input id="subject" class="form-control" value="SMTP 測試信 - TMC SHOP">
      </div>
    </div>

    <div class="form-group">
      <label>純文字內容（text）</label>
      <textarea id="text" class="form-control" rows="3">這是一封測試信（SMTP test）</textarea>
    </div>

    <div class="form-group">
      <label>HTML 內容（html）</label>
      <textarea id="html" class="form-control" rows="5"><b>這是一封測試信（SMTP test）</b><br><div style="color:#666;font-size:12px;">Sent at {{time}}</div></textarea>
      <div class="small-muted mt-1">會自動把 <code>{{time}}</code> 代換為現在時間。</div>
    </div>

    <div class="d-flex align-items-center">
      <button id="btnSend" class="btn btn-danger" onclick="sendTestEmail()">送出測試信</button>
      <div class="small-muted ml-3" id="resultHint"></div>
    </div>

    <div class="mt-3 small-muted">
      常見錯誤：
      <ul class="mb-0">
        <li><code>ENOTFOUND</code>：SMTP_HOST DNS/網域錯，或 VM DNS 設定問題</li>
        <li><code>ETIMEDOUT</code>：TCP 連線超時（防火牆/安全群組/網路封鎖 587/465）</li>
        <li><code>EAUTH</code>：帳密錯（Gmail 必須使用 App Password）</li>
      </ul>
    </div>
  </div>
</div>

<script>
  // ===== msgBox（同你全站一致）=====
  function showMsg(msg, type='danger', autoHideMs=0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger','alert-success','alert-warning','alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }
  function showSuccess(msg) { showMsg(msg, 'success', 800); } // ✅ 0.8 秒
  function showError(msg) { showMsg(msg, 'danger'); }
  function showInfo(msg) { showMsg(msg, 'info'); }

  function getApiErrorMessage(err, fallback='操作失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  function esc(s) {
    return String(s ?? '').replace(/[&<>"']/g, (m) => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'
    }[m]));
  }

  function setBadge(elId, ok, textOk='OK', textBad='FAIL') {
    const el = document.getElementById(elId);
    if (!el) return;
    el.innerText = ok ? textOk : textBad;
    el.style.background = ok ? 'rgba(40,167,69,.12)' : 'rgba(220,53,69,.12)';
    el.style.borderColor = ok ? 'rgba(40,167,69,.35)' : 'rgba(220,53,69,.35)';
    el.style.color = ok ? '#28a745' : '#dc3545';
  }

  function renderTips(tips) {
    const ul = document.getElementById('tipsList');
    if (!ul) return;
    ul.innerHTML = '';
    (Array.isArray(tips) ? tips : []).forEach(t => {
      const li = document.createElement('li');
      li.innerText = String(t);
      ul.appendChild(li);
    });
    if (!ul.children.length) {
      const li = document.createElement('li');
      li.innerText = '—';
      ul.appendChild(li);
    }
  }

  function showStatusBlocks(show) {
    document.getElementById('statusSummary').style.display = show ? 'block' : 'none';
    document.getElementById('statusDetails').style.display = show ? 'block' : 'none';
  }

  // ===== SMTP 狀態檢查 =====
  async function checkSmtpStatus() {
    const btn = document.getElementById('btnStatus');
    btn.disabled = true;
    showInfo('檢查中…（env / DNS / TCP，不發信）');

    try {
      const r = await axios.get('/api/admin/smtp-status', { params: { timeout: 3000 } });
      const data = r.data || {};

      showStatusBlocks(true);

      // summary
      const ok = data.status === 'ok';
      document.getElementById('statusSummary').innerHTML = `
        <div class="alert ${ok ? 'alert-success' : 'alert-warning'} mb-0">
          <b>${ok ? 'SMTP 狀態：OK' : 'SMTP 狀態：Not Ready'}</b>
          <span class="small-muted ml-2">timeout=${esc(data.timeoutMs)}ms</span>
        </div>
      `;

      // env
      setBadge('envBadge', Array.isArray(data.missing) ? data.missing.length === 0 : false, 'READY', 'MISSING');
      document.getElementById('envPre').innerText = JSON.stringify(data.env || {}, null, 2);
      const missing = Array.isArray(data.missing) ? data.missing : [];
      document.getElementById('missingPre').innerHTML = missing.length
        ? `<span class="text-danger">缺少：${missing.map(esc).join(', ')}</span>`
        : `<span class="text-success">環境變數齊全</span>`;

      // dns
      setBadge('dnsBadge', !!data.dns?.ok, 'OK', 'FAIL');
      document.getElementById('dnsPre').innerText = JSON.stringify(data.dns || {}, null, 2);

      // tcp
      setBadge('tcpBadge', !!data.tcp?.ok, 'OK', 'FAIL');
      document.getElementById('tcpPre').innerText = JSON.stringify(data.tcp || {}, null, 2);

      // tips
      renderTips(data.tips || []);

      if (ok) showSuccess('SMTP 狀態正常（env / DNS / TCP）');
      else showMsg('SMTP 狀態未就緒，請依 Tips 排查（env / DNS / TCP）', 'warning');

    } catch (e) {
      console.error(e);
      showError(getApiErrorMessage(e, '檢查失敗'));
      showStatusBlocks(false);
    } finally {
      btn.disabled = false;
    }
  }

  // ===== 發送測試信 =====
  async function sendTestEmail() {
    const btn = document.getElementById('btnSend');
    const hint = document.getElementById('resultHint');
    btn.disabled = true;
    hint.innerText = '';

    try {
      const to = (document.getElementById('to').value || '').trim();
      const subject = (document.getElementById('subject').value || '').trim();
      const text = (document.getElementById('text').value || '');
      let html = (document.getElementById('html').value || '');
      html = html.replaceAll('{{time}}', new Date().toISOString());

      showInfo('寄送中，請稍候…');

      const res = await axios.post('/api/admin/test-email', { to, subject, text, html });
      const data = res.data || {};

      showSuccess(`已送出測試信到：${data.to || to || '(self)'}（${data.ms || '?'}ms）`);
      hint.innerText = `messageId: ${data.messageId || '—'}`;

    } catch (e) {
      console.error(e);
      const msg = getApiErrorMessage(e, '寄送失敗');
      const code = e?.response?.data?.code ? `（${e.response.data.code}）` : '';
      showError(msg + code);
    } finally {
      btn.disabled = false;
    }
  }

  // 頁面進來自動跑一次狀態檢查（企業常見：一進頁就看到狀態）
  $(document).ready(() => {
    checkSmtpStatus().catch(()=>{});
  });
</script>
