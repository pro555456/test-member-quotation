<!-- 3) views/reset_password.ejs -->
 <%- include('./basic/auth_card.ejs', {
  authWrapClass: 'auth-wrap-md',
  titleText: '重設密碼',
  subtitleText: '請輸入新密碼，完成後即可用新密碼登入',
  body: `
    <div id="pwdHint" class="small-muted mb-3">密碼規則載入中...</div>

    <div class="form-group">
      <label for="password">新密碼</label>
      <input id="password" type="password" class="form-control" placeholder="請輸入新密碼">
    </div>

    <div class="form-group">
      <label for="password2">確認新密碼</label>
      <input id="password2" type="password" class="form-control" placeholder="請再次輸入新密碼">
    </div>

    <div class="text-center mb-3">
      <span class="small-muted">想返回登入？</span>
      <a href="/login" class="ml-1">前往登入</a>
    </div>

    <div class="text-center">
      <button id="btnReset" type="button" onclick="resetPassword()" class="btn btn-danger mr-2">送出</button>
      <button type="button" class="btn btn-outline-secondary" onclick="resetForm()">重填</button>
    </div>
  `
}) %>

<script>
  let securityCfg = {
    PWD_MIN: 10,
    PWD_MAX: 72,
    passwordPolicyText: '密碼需符合系統規則（需包含大小寫字母、數字與符號，且不可包含帳號）'
  };

  function showMsg(msg, type='danger', autoHideMs=0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showError(msg) { showMsg(msg, 'danger'); }
  function showSuccess(msg) { showMsg(msg, 'success', 800); }
  function showInfo(msg) { showMsg(msg, 'info'); }

  function clearMsg() {
    const box = document.getElementById('msgBox');
    box.style.display = 'none';
    box.innerText = '';
  }

  function getApiErrorMessage(err, fallback='操作失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function apiRequest(method, url, data, opts = {}) {
    try {
      const res = await axios({ method, url, data });
      return res.data;
    } catch (err) {
      const msg = getApiErrorMessage(err);
      console.error('[API ERROR]', { method, url, msg, data, err, response: err?.response?.data });
      if (!opts?.silent) showError(msg);
      throw err;
    }
  }

  function getQuery(name) {
    const u = new URL(window.location.href);
    return u.searchParams.get(name);
  }

  function applySecurityConfigToUI() {
    const pwdHint = document.getElementById('pwdHint');
    if (pwdHint) pwdHint.innerText = securityCfg.passwordPolicyText || '';

    const pwd = document.getElementById('password');
    const pwd2 = document.getElementById('password2');

    if (pwd) {
      pwd.setAttribute('maxlength', String(securityCfg.PWD_MAX));
      pwd.setAttribute('placeholder', `請輸入符合規則的新密碼（${securityCfg.PWD_MIN}～${securityCfg.PWD_MAX}碼）`);
    }
    if (pwd2) {
      pwd2.setAttribute('maxlength', String(securityCfg.PWD_MAX));
    }
  }

  async function loadSecurityConfig() {
    try {
      const data = await apiRequest('get', '/api/security/config', null, { silent: true });
      securityCfg = {
        PWD_MIN: Number(data.PWD_MIN) || securityCfg.PWD_MIN,
        PWD_MAX: Number(data.PWD_MAX) || securityCfg.PWD_MAX,
        passwordPolicyText: String(data.passwordPolicyText || securityCfg.passwordPolicyText)
      };
    } catch {
    } finally {
      applySecurityConfigToUI();
    }
  }

  function resetForm() {
    document.getElementById('password').value = '';
    document.getElementById('password2').value = '';
    clearMsg();
  }

  async function resetPassword() {
    const btn = document.getElementById('btnReset');
    btn.disabled = true;
    clearMsg();

    try {
      const token = getQuery('token');
      const password = document.getElementById('password').value || '';
      const password2 = document.getElementById('password2').value || '';

      if (!token) {
        showError('缺少 token');
        return;
      }
      if (!password.trim()) {
        showError('請輸入新密碼');
        return;
      }
      if (password !== password2) {
        showError('兩次輸入的新密碼不一致');
        return;
      }

      showInfo('送出中…');

      const data = await apiRequest('post', '/api/auth/reset-password', {
        token,
        newPassword: password
      });

      showSuccess(data?.message || '密碼已重設');

      setTimeout(() => {
        window.location.assign('/login');
      }, 850);
    } catch (e) {
    } finally {
      btn.disabled = false;
    }
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      const active = document.activeElement;
      if (active && (active.id === 'password' || active.id === 'password2')) {
        e.preventDefault();
        resetPassword();
      }
    }
  });

  $(document).ready(() => {
    loadSecurityConfig().catch(() => {});
  });
</script>