<script>
  let securityCfg = {
    ACCOUNT_MIN: 3,
    ACCOUNT_MAX: 32,
    EMAIL_MAX: 200,
    PWD_MIN: 10,
    PWD_MAX: 72,
    passwordPolicyText: 'ж’–пүҺв…Ј?ВҖиқҡиЎҖ?иқҹйӨҢзөһй–¬оҗұ?еҡ—пҺҠ??пҶҜо’”жҶӯжү№?ж’–жҖ ?зҳҘпҡ•ВҖојјоһІж‘®оӨң?иқҡиҘҝ?еҡ—п—№?йҠқпҡ—оҸ»?пҶҜо’”ж’Је”ҫ?еҡ—?
  };

  function showMsg(msg, type='danger', autoHideMs=0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showError(msg) { showMsg(msg, 'danger'); }
  function showSuccess(msg) { showMsg(msg, 'success', 800); }
  function showInfo(msg) { showMsg(msg, 'info'); }

  function clearMsg() {
    const box = document.getElementById('msgBox');
    box.style.display = 'none';
    box.innerText = '';
  }

  function getApiErrorMessage(err, fallback='?пҡ–?жҶӯжңӣ?') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function apiRequest(method, url, data, opts = {}) {
    try {
      const res = await axios({ method, url, data });
      return res.data;
    } catch (err) {
      const msg = getApiErrorMessage(err);
      console.error('[API ERROR]', { method, url, msg, data, err, response: err?.response?.data });
      if (!opts?.silent) showError(msg);
      throw err;
    }
  }

  function applySecurityConfigToUI() {
    const acc = document.getElementById('account');
    if (acc) {
      acc.setAttribute('maxlength', String(securityCfg.ACCOUNT_MAX));
      acc.setAttribute('placeholder', `йқҳп•§?user01 / wilson.tsaiеҡ—?{securityCfg.ACCOUNT_MIN}еҡҡ?{securityCfg.ACCOUNT_MAX}иқЈжҪҳ?`);
    }

    const accountHint = document.getElementById('accountHint');
    if (accountHint) {
      accountHint.innerText = `ж’Је”ҫ?еҡ—?{securityCfg.ACCOUNT_MIN}еҡҡ?{securityCfg.ACCOUNT_MAX}иқЈжҪҳ?ж“җоЎј?зҳҘпҡҡп”©?пӢ©?зҳҘпҡЎ??иҮ¬о’” . _ -`;
    }

    const em = document.getElementById('email');
    if (em) {
      em.setAttribute('maxlength', String(securityCfg.EMAIL_MAX));
      em.setAttribute('placeholder', `йқҳп•§?name@example.comеҡ—пҺҮ???${securityCfg.EMAIL_MAX} ж‘®оӨЈ?`);
    }

    const emailHint = document.getElementById('emailHint');
    if (emailHint) {
      emailHint.innerText = `Emailеҡ—о«ұ???${securityCfg.EMAIL_MAX} ж‘®оӨЈ??ВҖ?з®Ҹ?зҳң?Email ?жҫҶ?`;
    }

    const pwd = document.getElementById('password');
    if (pwd) {
      pwd.setAttribute('maxlength', String(securityCfg.PWD_MAX));
      pwd.setAttribute('placeholder', `йҡўп• ж’“?дәҰжіө?пҺү??пӢ«?ж’–пүҺв…Јеҡ—?{securityCfg.PWD_MIN}еҡҡ?{securityCfg.PWD_MAX}иқЈжҪҳ?`);
    }

    const pwdHint = document.getElementById('pwdHint');
    if (pwdHint) {
      pwdHint.innerText = securityCfg.passwordPolicyText || '';
    }
  }

  async function loadSecurityConfig() {
    try {
      const data = await apiRequest('get', '/api/security/config', null, { silent: true });
      securityCfg = {
        ACCOUNT_MIN: Number(data.ACCOUNT_MIN) || securityCfg.ACCOUNT_MIN,
        ACCOUNT_MAX: Number(data.ACCOUNT_MAX) || securityCfg.ACCOUNT_MAX,
        EMAIL_MAX: Number(data.EMAIL_MAX) || securityCfg.EMAIL_MAX,
        PWD_MIN: Number(data.PWD_MIN) || securityCfg.PWD_MIN,
        PWD_MAX: Number(data.PWD_MAX) || securityCfg.PWD_MAX,
        passwordPolicyText: String(data.passwordPolicyText || securityCfg.passwordPolicyText)
      };
    } catch {
    } finally {
      applySecurityConfigToUI();
    }
  }

  function resetForm() {
    ['name', 'cellphone', 'email', 'birthday', 'account', 'password', 'password2'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = '';
    });
    clearMsg();
  }

  async function doRegister() {
    const btn = document.getElementById('btnRegister');
    btn.disabled = true;
    clearMsg();

    try {
      const name = (document.getElementById('name').value || '').trim();
      const cellphone = (document.getElementById('cellphone').value || '').trim();
      const email = (document.getElementById('email').value || '').trim();
      const birthday = (document.getElementById('birthday').value || '').trim();
      const account = (document.getElementById('account').value || '').trim();
      const password = document.getElementById('password').value || '';
      const password2 = document.getElementById('password2').value || '';

      if (!account) { showError('йҡўп• ж’“?дәҷи‘Ј??); return; }
      if (!password.trim()) { showError('йҡўп• ж’“?дәҷ?иқЈ?); return; }
      if (password !== password2) { showError('?жӢҮжҙ»ж’–пүҺв…ЈйҠқпҡ–??ж№ӣ?йҡўп•Ў??е•—ж’“??); return; }
      if (!cellphone) { showError('?п•һ??з®Ҹ?жҶӣ?); return; }
      if (!email) { showError('Email ?з®Ҹ?жҶӣ?); return; }

      showInfo('?ој»пҠҫй–®йӨғ?йҠқеҮҢВҖ?);

      const data = await apiRequest('post', '/api/register', {
        account,
        password,
        name,
        cellphone,
        email,
        birthday
      });

      showSuccess(data?.message || 'й–®йӨғ?ж’Ңи„ӨВҖој»пҠҫ');

      setTimeout(() => {
        window.location.assign('/login');
      }, 850);

    } catch (e) {
    } finally {
      btn.disabled = false;
    }
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      const active = document.activeElement;
      if (active && ['name','cellphone','email','birthday','account','password','password2'].includes(active.id)) {
        e.preventDefault();
        doRegister();
      }
    }
  });

  $(document).ready(() => {
    loadSecurityConfig().catch(() => {});
  });
</script>
