<%- include('./basic/auth_card.ejs', {
  authWrapClass: '',
  titleText: '會員註冊',
  subtitleText: '建立您的 TMC SHOP 帳號，完成 Email 驗證後即可使用',
  body: `
    <div class="form-group">
      <label for="name">姓名</label>
      <input id="name" class="form-control" placeholder="請輸入姓名">
    </div>

    <div class="form-group">
      <label for="cellphone">連絡電話（必填）</label>
      <input id="cellphone" class="form-control" placeholder="例：09xxxxxxxx">
    </div>

    <div class="form-group">
      <label for="email">Email（必填）</label>
      <input id="email" class="form-control" placeholder="例：name@example.com">
      <div id="emailHint" class="small-muted mt-1">Email 規則載入中...</div>
    </div>

    <div class="form-group">
      <label for="birthday">生日（選填）</label>
      <input id="birthday" class="form-control" placeholder="YYYY-MM-DD 例如 2022-01-01">
    </div>

    <hr/>

    <div class="form-group">
      <label for="account">帳號</label>
      <input id="account" class="form-control" placeholder="帳號規則載入中...">
      <div id="accountHint" class="small-muted mt-1">帳號規則載入中...</div>
    </div>

    <div class="form-group">
      <label for="password">密碼</label>
      <input id="password" type="password" class="form-control" placeholder="密碼規則載入中...">
      <div id="pwdHint" class="small-muted mt-1">密碼規則載入中...</div>
    </div>

    <div class="form-group">
      <label for="password2">確認密碼</label>
      <input id="password2" type="password" class="form-control" placeholder="請再輸入一次密碼">
    </div>

    <div class="text-center mb-3">
      <span class="small-muted">已經有帳號？</span>
      <a href="/login" class="ml-1">前往登入</a>
    </div>

    <div class="text-center">
      <button id="btnRegister" type="button" onclick="doRegister()" class="btn btn-danger mr-2">註冊</button>
      <button type="button" class="btn btn-outline-secondary" onclick="resetForm()">重填</button>
    </div>
  `
}) %>

<script>
  let securityCfg = {
    ACCOUNT_MIN: 3,
    ACCOUNT_MAX: 32,
    EMAIL_MAX: 200,
    PWD_MIN: 10,
    PWD_MAX: 72,
    passwordPolicyText: '密碼需符合系統規則（需包含大小寫字母、數字與符號，且不可包含帳號）'
  };

  function showMsg(msg, type='danger', autoHideMs=0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showError(msg) { showMsg(msg, 'danger'); }
  function showSuccess(msg) { showMsg(msg, 'success', 800); }
  function showInfo(msg) { showMsg(msg, 'info'); }

  function clearMsg() {
    const box = document.getElementById('msgBox');
    box.style.display = 'none';
    box.innerText = '';
  }

  function getApiErrorMessage(err, fallback='操作失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function apiRequest(method, url, data, opts = {}) {
    try {
      const res = await axios({ method, url, data });
      return res.data;
    } catch (err) {
      const msg = getApiErrorMessage(err);
      console.error('[API ERROR]', { method, url, msg, data, err, response: err?.response?.data });
      if (!opts?.silent) showError(msg);
      throw err;
    }
  }

  function applySecurityConfigToUI() {
    const acc = document.getElementById('account');
    if (acc) {
      acc.setAttribute('maxlength', String(securityCfg.ACCOUNT_MAX));
      acc.setAttribute('placeholder', `例：user01 / wilson.tsai（${securityCfg.ACCOUNT_MIN}～${securityCfg.ACCOUNT_MAX}碼）`);
    }

    const accountHint = document.getElementById('accountHint');
    if (accountHint) {
      accountHint.innerText = `帳號：${securityCfg.ACCOUNT_MIN}～${securityCfg.ACCOUNT_MAX}碼，首字母英文字母，可含 . _ -`;
    }

    const em = document.getElementById('email');
    if (em) {
      em.setAttribute('maxlength', String(securityCfg.EMAIL_MAX));
      em.setAttribute('placeholder', `例：name@example.com（最長 ${securityCfg.EMAIL_MAX} 字）`);
    }

    const emailHint = document.getElementById('emailHint');
    if (emailHint) {
      emailHint.innerText = `Email：最長 ${securityCfg.EMAIL_MAX} 字，需為合法 Email 格式`;
    }

    const pwd = document.getElementById('password');
    if (pwd) {
      pwd.setAttribute('maxlength', String(securityCfg.PWD_MAX));
      pwd.setAttribute('placeholder', `請輸入符合規則的密碼（${securityCfg.PWD_MIN}～${securityCfg.PWD_MAX}碼）`);
    }

    const pwdHint = document.getElementById('pwdHint');
    if (pwdHint) {
      pwdHint.innerText = securityCfg.passwordPolicyText || '';
    }
  }

  async function loadSecurityConfig() {
    try {
      const data = await apiRequest('get', '/api/security/config', null, { silent: true });
      securityCfg = {
        ACCOUNT_MIN: Number(data.ACCOUNT_MIN) || securityCfg.ACCOUNT_MIN,
        ACCOUNT_MAX: Number(data.ACCOUNT_MAX) || securityCfg.ACCOUNT_MAX,
        EMAIL_MAX: Number(data.EMAIL_MAX) || securityCfg.EMAIL_MAX,
        PWD_MIN: Number(data.PWD_MIN) || securityCfg.PWD_MIN,
        PWD_MAX: Number(data.PWD_MAX) || securityCfg.PWD_MAX,
        passwordPolicyText: String(data.passwordPolicyText || securityCfg.passwordPolicyText)
      };
    } catch {
    } finally {
      applySecurityConfigToUI();
    }
  }

  function resetForm() {
    ['name', 'cellphone', 'email', 'birthday', 'account', 'password', 'password2'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = '';
    });
    clearMsg();
  }

  async function doRegister() {
    const btn = document.getElementById('btnRegister');
    btn.disabled = true;
    clearMsg();

    try {
      const name = (document.getElementById('name').value || '').trim();
      const cellphone = (document.getElementById('cellphone').value || '').trim();
      const email = (document.getElementById('email').value || '').trim();
      const birthday = (document.getElementById('birthday').value || '').trim();
      const account = (document.getElementById('account').value || '').trim();
      const password = document.getElementById('password').value || '';
      const password2 = document.getElementById('password2').value || '';

      if (!account) { showError('請輸入帳號'); return; }
      if (!password.trim()) { showError('請輸入密碼'); return; }
      if (password !== password2) { showError('兩次密碼不一致，請重新輸入'); return; }
      if (!cellphone) { showError('手機為必填'); return; }
      if (!email) { showError('Email 為必填'); return; }

      showInfo('送出註冊中…');

      const data = await apiRequest('post', '/api/register', {
        account,
        password,
        name,
        cellphone,
        email,
        birthday
      });

      showSuccess(data?.message || '註冊已送出');

      setTimeout(() => {
        window.location.assign('/login');
      }, 850);

    } catch (e) {
    } finally {
      btn.disabled = false;
    }
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      const active = document.activeElement;
      if (active && ['name','cellphone','email','birthday','account','password','password2'].includes(active.id)) {
        e.preventDefault();
        doRegister();
      }
    }
  });

  $(document).ready(() => {
    loadSecurityConfig().catch(() => {});
  });
</script>