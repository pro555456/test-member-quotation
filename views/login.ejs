<%- include('./basic/auth_card.ejs', {
  authWrapClass: 'auth-wrap-sm',
  titleText: '遊戲檢測報價平台',
  subtitleText: '登入後即可查看報價單、案件追蹤與營運儀表板。',
  body: `
    <div class="form-group">
      <label for="account">帳號</label>
      <input id="account" class="form-control" name="account" placeholder="請輸入帳號" autocomplete="username">
    </div>

    <div class="form-group">
      <label for="password">密碼</label>
      <input id="password" class="form-control" name="password" type="password" placeholder="請輸入密碼" autocomplete="current-password">
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <div class="small-muted">內部人員登入入口</div>
      <div><a href="/forgot-password">忘記密碼</a></div>
    </div>

    <div class="text-center">
      <button id="btnLogin" type="button" onclick="login()" class="btn btn-danger mr-2">登入</button>
      <button type="button" class="btn btn-outline-secondary" onclick="resetForm()">清除</button>
    </div>
  `
}) %>

<script>
  function showMsg(msg, type = 'danger', autoHideMs = 0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';

    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function clearMsg() {
    const box = document.getElementById('msgBox');
    box.style.display = 'none';
    box.innerText = '';
  }

  function resetForm() {
    document.getElementById('account').value = '';
    document.getElementById('password').value = '';
    clearMsg();
  }

  function checkVerifiedFlag() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('verified') === '1') {
      showMsg('Email 驗證完成，請重新登入。', 'success', 1200);
      setTimeout(() => {
        const url = new URL(window.location.href);
        url.searchParams.delete('verified');
        window.history.replaceState({}, '', url.pathname);
      }, 1300);
    }
  }

  async function login() {
    const btn = document.getElementById('btnLogin');
    btn.disabled = true;
    clearMsg();

    try {
      const account = (document.getElementById('account').value || '').trim();
      const password = document.getElementById('password').value || '';

      if (!account) {
        showMsg('請輸入帳號');
        return;
      }
      if (!password) {
        showMsg('請輸入密碼');
        return;
      }

      await axios.post('/api/login', { account, password });
      window.location.href = '/dashboard';
    } catch (err) {
      const msg = err?.response?.data?.message || '登入失敗，請檢查帳號密碼。';
      showMsg(msg);
    } finally {
      btn.disabled = false;
    }
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      const active = document.activeElement;
      if (active && (active.id === 'account' || active.id === 'password')) {
        e.preventDefault();
        login();
      }
    }
  });

  $(document).ready(function () {
    checkVerifiedFlag();
  });
</script>
