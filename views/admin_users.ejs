<!-- 四、B：更新 admin_users.ejs（整份可覆蓋版：在「詳情 modal」內可編輯並儲存）

你目前 admin_users.ejs 很長，我不想用「只給片段」讓你自己找位置出錯，所以我給你整份可覆蓋版（基於你上一版：含規則同步、apiRequest、modal 訊息顯示、0.8 秒後關閉 create/pwd 成功）。

✅ 主要新增：

detailModal 內新增 detailMsgBox（顯示更新成功/錯誤）

detailModal 內把 name/cellphone/email 改成 input（可編輯）

新增 saveDetailProfile() → PATCH /api/admin/users/:id/profile

成功訊息只顯示在 detailModal（不打到主頁 msgBox）

你原本的 audit 表、載入更多、停用/角色/重設都保留

⚠️ 由於篇幅很長，我會把「新增/修改的 detailModal + JS」做成完整可覆蓋版，但其餘結構與你上版一致。你直接整檔覆蓋即可。 -->

<%
  style = `
  <style>
    .small-muted { font-size: 12px; color: #666; }
    pre.audit-pre { margin:0; white-space:pre-wrap; }
  </style>
  `;
%>

<div class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-2">
  <h2 class="text-danger m-0">人員管理</h2>

  <div>
    <a class="btn btn-outline-secondary mr-2" href="/profile">我的資料</a>
    <button class="btn btn-success" onclick="openCreateModal()">新增人員</button>
  </div>
</div>

  <div class="border p-2 mb-3">
    <div class="form-row align-items-end">
      <div class="col-md-3 mb-2">
        <label class="m-0">關鍵字（帳號 / 姓名 / Email / 手機）</label>
        <input id="kw" class="form-control" placeholder="輸入關鍵字">
      </div>

      <div class="col-md-2 mb-2">
        <label class="m-0">狀態</label>
        <select id="statusFilter" class="form-control">
          <option value="">全部</option>
          <option value="0">啟用</option>
          <option value="1">停用</option>
        </select>
      </div>

      <div class="col-md-3 mb-2">
        <label class="m-0">角色（包含）</label>
        <select id="roleFilter" class="form-control">
          <option value="">全部角色</option>
        </select>
        <div class="small-muted">提示：選一個角色就只顯示包含該角色的使用者</div>
      </div>

      <div class="col-md-4 mb-2 text-right">
        <button class="btn btn-outline-secondary mr-2" onclick="resetFilters()">清除篩選</button>
        <button class="btn btn-primary" onclick="applyFilters()">套用</button>
      </div>
    </div>

    <div id="msgBox" class="alert mt-2" style="display:none;"></div>
  </div>

  <table id="usersTable" class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>ID</th>
        <th>帳號</th>
        <th>姓名</th>
        <th>手機</th>
        <th>Email</th>
        <th>角色</th>
        <th>狀態</th>
        <th style="width: 270px;">操作</th>
      </tr>
    </thead>
    <tbody class="users-content"></tbody>
  </table>
</div>

<!-- 停用原因 Modal -->
<div class="modal fade" id="disableModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">停用帳號</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body">
        <div class="small-muted mb-2">建議填寫原因（可留空）</div>
        <textarea id="disableReason" class="form-control" rows="3" placeholder="例：離職 / 權限調整 / 風控..."></textarea>
      </div>
      <div class="modal-footer">
        <button class="btn btn-danger" onclick="confirmDisable()">確認停用</button>
        <button class="btn btn-secondary" data-dismiss="modal">取消</button>
      </div>
    </div>
  </div>
</div>

<!-- 角色設定 Modal -->
<div class="modal fade" id="roleModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">指派角色</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body">
        <div class="mb-2">
          <button class="btn btn-sm btn-outline-secondary mr-2" onclick="checkAllRoles(true)">全選</button>
          <button class="btn btn-sm btn-outline-secondary" onclick="checkAllRoles(false)">全不選</button>
        </div>
        <div id="roleList"></div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-primary" onclick="saveRoles()">儲存</button>
        <button class="btn btn-secondary" data-dismiss="modal">取消</button>
      </div>
    </div>
  </div>
</div>

<!-- 重設密碼 Modal -->
<div class="modal fade" id="pwdModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">重設密碼</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>

      <div class="modal-body">
        <div id="pwdMsgBox" class="alert" style="display:none;"></div>

        <div class="form-group">
          <label>新密碼</label>
          <input id="newPwd" type="password" class="form-control" placeholder="********">
          <div id="pwdPolicyText1" class="small-muted mt-1">密碼規則載入中...</div>
          <div class="small-muted mt-1">重設後會寫入審計欄位與 audit log</div>
        </div>
      </div>

      <div class="modal-footer">
        <button id="btnResetPwd" class="btn btn-danger" onclick="resetPassword()">確認重設</button>
        <button class="btn btn-secondary" data-dismiss="modal">取消</button>
      </div>
    </div>
  </div>
</div>

<!-- 新增人員 Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">新增人員</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>

      <div class="modal-body">
        <div id="createMsgBox" class="alert" style="display:none;"></div>

        <div class="form-group">
          <label>帳號</label>
          <input id="cAccount" class="form-control">
          <div id="accountHint" class="small-muted mt-1">帳號規則載入中...</div>
        </div>

        <div class="form-group">
          <label>密碼</label>
          <input id="cPassword" type="password" class="form-control">
          <div id="pwdPolicyText2" class="small-muted mt-1">密碼規則載入中...</div>
        </div>

        <div class="form-group">
          <label>姓名</label>
          <input id="cName" class="form-control">
        </div>

        <div class="form-group">
          <label>手機（必填）</label>
          <input id="cCell" class="form-control" placeholder="例：09xxxxxxxx">
        </div>

        <div class="form-group">
          <label>Email（必填）</label>
          <input id="cEmail" class="form-control">
          <div id="emailHint" class="small-muted mt-1">Email 規則載入中...</div>
        </div>

        <hr/>
        <div class="d-flex justify-content-between align-items-center">
          <b>指派角色</b>
          <div>
            <button class="btn btn-sm btn-outline-secondary mr-1" onclick="checkAllCreateRoles(true)">全選</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="checkAllCreateRoles(false)">全不選</button>
          </div>
        </div>
        <div id="createRoleList" class="mt-2"></div>
      </div>

      <div class="modal-footer">
        <button id="btnCreateUser" class="btn btn-success" onclick="createUser()">建立</button>
        <button class="btn btn-secondary" data-dismiss="modal">取消</button>
      </div>
    </div>
  </div>
</div>

<!-- Detail + Audit Modal（✅ 這裡改成可編輯） -->
<div class="modal fade" id="detailModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">使用者詳情 / 操作紀錄</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>

      <div class="modal-body">
        <!-- ✅ detail 的訊息顯示（成功/失敗都在這裡） -->
        <div id="detailMsgBox" class="alert" style="display:none;"></div>

        <div class="border p-2 mb-3">
          <div class="form-row">
            <div class="form-group col-md-4">
              <label>ID</label>
              <input id="dId" class="form-control" disabled>
            </div>
            <div class="form-group col-md-4">
              <label>帳號（不可修改）</label>
              <input id="dAccount" class="form-control" disabled>
            </div>
            <div class="form-group col-md-4">
              <label>建立/更新</label>
              <input id="dDates" class="form-control" disabled>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-4">
              <label>姓名</label>
              <input id="dName" class="form-control" maxlength="50">
            </div>

            <div class="form-group col-md-4">
              <label>手機（必填）</label>
              <input id="dCell" class="form-control" maxlength="15" placeholder="例：09xxxxxxxx">
            </div>

            <div class="form-group col-md-4">
              <label>Email（必填）</label>
              <input id="dEmail" class="form-control">
              <div class="small-muted mt-1">（規則由 /api/security/config 同步）</div>
            </div>
          </div>

          <div class="d-flex justify-content-between align-items-center">
            <div class="small-muted" id="dMetaText"></div>
            <button id="btnSaveDetail" class="btn btn-sm btn-primary" onclick="saveDetailProfile()">儲存基本資料</button>
          </div>

          <div class="small-muted mt-2" id="dAuditText"></div>
        </div>

        <div class="d-flex justify-content-between align-items-center">
          <h5 class="m-0">最近操作紀錄</h5>
          <div class="small-muted">顯示最新在上方</div>
        </div>

        <table class="table table-sm table-bordered mt-2">
          <thead>
            <tr>
              <th style="width: 150px;">時間</th>
              <th style="width: 120px;">操作者</th>
              <th style="width: 160px;">動作</th>
              <th>細節</th>
              <th style="width: 120px;">IP</th>
            </tr>
          </thead>
          <tbody id="auditRows"></tbody>
        </table>

        <div class="text-center">
          <button id="btnMoreAudit" class="btn btn-outline-secondary btn-sm" onclick="loadMoreAudit()">載入更多</button>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-dismiss="modal">關閉</button>
      </div>
    </div>
  </div>
</div>

<script>
  let users = [];
  let roles = [];
  let selectedUserId = null;

  let disableTargetId = null;

  let auditTargetId = null;
  let auditOffset = 0;
  const auditLimit = 50;

  // ✅ detail 目前正在編輯的 target
  let detailTargetId = null;

  let dt = null;

  // ===== 規則同步 =====
  let securityCfg = {
    ACCOUNT_MIN: 3,
    ACCOUNT_MAX: 32,
    EMAIL_MAX: 200,
    PWD_MIN: 10,
    PWD_MAX: 72,
    passwordPolicyText: '密碼需符合系統規則（需包含大小寫字母、數字與符號，且不可包含帳號）'
  };

  function showMsg(msg, type = 'danger') {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger','alert-success','alert-warning','alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
  function showError(msg) { showMsg(msg, 'danger'); }
  function showSuccess(msg) { showMsg(msg, 'success'); }
  function clearMsg() {
    const box = document.getElementById('msgBox');
    box.style.display = 'none';
    box.innerText = '';
  }

  function showModalMsg(boxId, msg, type = 'danger') {
    const box = document.getElementById(boxId);
    if (!box) return;
    box.style.display = 'block';
    box.classList.remove('alert-danger','alert-success','alert-warning','alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
  }
  function clearModalMsg(boxId) {
    const box = document.getElementById(boxId);
    if (!box) return;
    box.style.display = 'none';
    box.innerText = '';
  }

  function showCreateError(msg) { showModalMsg('createMsgBox', msg, 'danger'); }
  function showCreateSuccess(msg) { showModalMsg('createMsgBox', msg, 'success'); }
  function showPwdError(msg) { showModalMsg('pwdMsgBox', msg, 'danger'); }
  function showPwdSuccess(msg) { showModalMsg('pwdMsgBox', msg, 'success'); }

  function showDetailError(msg) { showModalMsg('detailMsgBox', msg, 'danger'); }
  function showDetailSuccess(msg) { showModalMsg('detailMsgBox', msg, 'success'); }

  function getApiErrorMessage(err, fallback = '操作失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function apiRequest(method, url, data, opts = {}) {
    try {
      const res = await axios({ method, url, data });
      return res.data;
    } catch (err) {
      const msg = getApiErrorMessage(err);
      console.error('[API ERROR]', { method, url, msg, data, err, response: err?.response?.data });

      if (!opts?.silent) {
        if (typeof opts?.onError === 'function') opts.onError(msg, err);
        else showError(msg);
      }
      throw err;
    }
  }

  function closeModalAfter(modalSelector, ms = 800) {
    return new Promise(resolve => {
      setTimeout(() => {
        $(modalSelector).modal('hide');
        resolve();
      }, ms);
    });
  }

  function escapeHtml(str) {
    return String(str ?? '').replace(/[&<>"']/g, (m) => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'
    }[m]));
  }

  function formatDetail(detailJson) {
    if (!detailJson) return '';
    try {
      if (typeof detailJson === 'string') return detailJson;
      return JSON.stringify(detailJson, null, 2);
    } catch {
      return String(detailJson);
    }
  }

  function applySecurityConfigToUI() {
    const t = securityCfg.passwordPolicyText || '';
    const el1 = document.getElementById('pwdPolicyText1');
    const el2 = document.getElementById('pwdPolicyText2');
    if (el1) el1.innerText = t;
    if (el2) el2.innerText = t;

    const acc = document.getElementById('cAccount');
    if (acc) {
      acc.setAttribute('maxlength', String(securityCfg.ACCOUNT_MAX));
      acc.setAttribute('placeholder', `例：staff01 / admin.test（${securityCfg.ACCOUNT_MIN}～${securityCfg.ACCOUNT_MAX}碼，首字母英文字母）`);
    }
    const accHint = document.getElementById('accountHint');
    if (accHint) accHint.innerText = `帳號：${securityCfg.ACCOUNT_MIN}～${securityCfg.ACCOUNT_MAX}碼，首字母英文字母，可含 . _ -`;

    const em = document.getElementById('cEmail');
    if (em) {
      em.setAttribute('maxlength', String(securityCfg.EMAIL_MAX));
      em.setAttribute('placeholder', `例：name@example.com（最長 ${securityCfg.EMAIL_MAX} 字）`);
    }
    const emailHint = document.getElementById('emailHint');
    if (emailHint) emailHint.innerText = `Email：最長 ${securityCfg.EMAIL_MAX} 字，需為合法 Email 格式`;

    const pwd = document.getElementById('cPassword');
    if (pwd) {
      pwd.setAttribute('maxlength', String(securityCfg.PWD_MAX));
      pwd.setAttribute('placeholder', `請輸入符合規則的密碼（${securityCfg.PWD_MIN}～${securityCfg.PWD_MAX}碼）`);
    }
    const newPwd = document.getElementById('newPwd');
    if (newPwd) {
      newPwd.setAttribute('maxlength', String(securityCfg.PWD_MAX));
      newPwd.setAttribute('placeholder', `請輸入新密碼（${securityCfg.PWD_MIN}～${securityCfg.PWD_MAX}碼）`);
    }

    // ✅ detailModal 的 email maxlength 同步
    const dEmail = document.getElementById('dEmail');
    if (dEmail) dEmail.setAttribute('maxlength', String(securityCfg.EMAIL_MAX));
  }

  async function loadSecurityConfig() {
    try {
      const data = await apiRequest('get', '/api/security/config');
      securityCfg = {
        ACCOUNT_MIN: Number(data.ACCOUNT_MIN) || securityCfg.ACCOUNT_MIN,
        ACCOUNT_MAX: Number(data.ACCOUNT_MAX) || securityCfg.ACCOUNT_MAX,
        EMAIL_MAX: Number(data.EMAIL_MAX) || securityCfg.EMAIL_MAX,
        PWD_MIN: Number(data.PWD_MIN) || securityCfg.PWD_MIN,
        PWD_MAX: Number(data.PWD_MAX) || securityCfg.PWD_MAX,
        passwordPolicyText: String(data.passwordPolicyText || securityCfg.passwordPolicyText),
      };
    } catch (e) {
      console.warn('[security/config] fallback to defaults');
    } finally {
      applySecurityConfigToUI();
    }
  }

  async function loadData() {
    const [uRes, rRes] = await Promise.all([
      apiRequest('get', '/api/admin/users'),
      apiRequest('get', '/api/admin/roles')
    ]);
    users = uRes.users || [];
    roles = rRes.roles || [];

    const roleFilter = document.getElementById('roleFilter');
    roleFilter.innerHTML = `<option value="">全部角色</option>` + roles.map(r => (
      `<option value="${r.id}">${escapeHtml(r.name)} (${escapeHtml(r.code)})</option>`
    )).join('');

    renderTable(users);
  }

  function buildRow(u) {
    const roleText = (u.roles || []).map(r => r.name).join(', ') || '—';
    const status = u.is_disabled ? `<span class="text-danger">停用</span>` : `<span class="text-success">啟用</span>`;

    const btnDisable = u.is_disabled
      ? `<button class="btn btn-sm btn-success mr-1" onclick="toggleDisable(${u.id}, false)">啟用</button>`
      : `<button class="btn btn-sm btn-danger mr-1" onclick="openDisableModal(${u.id})">停用</button>`;

    return [
      u.id,
      escapeHtml(u.account),
      escapeHtml(u.name || ''),
      escapeHtml(u.cellphone || ''),
      escapeHtml(u.email || ''),
      escapeHtml(roleText),
      status,
      `
        <div style="white-space:nowrap;">
          <button class="btn btn-sm btn-primary mr-1" onclick="openRoleModal(${u.id})">角色</button>
          <button class="btn btn-sm btn-warning mr-1" onclick="openPwdModal(${u.id})">重設</button>
          ${btnDisable}
          <button class="btn btn-sm btn-info" onclick="openDetailModal(${u.id})">詳情</button>
        </div>
      `
    ];
  }

  function renderTable(list) {
    const data = list.map(buildRow);

    if (!dt) {
      dt = $('#usersTable').DataTable({
        info: false,
        data,
        columns: [
          { title: 'ID' },
          { title: '帳號' },
          { title: '姓名' },
          { title: '手機' },
          { title: 'Email' },
          { title: '角色' },
          { title: '狀態' },
          { title: '操作', orderable:false }
        ]
      });
    } else {
      dt.clear();
      dt.rows.add(data);
      dt.draw(false);
    }
  }

  function applyFilters() {
    const kw = (document.getElementById('kw').value || '').trim().toLowerCase();
    const st = document.getElementById('statusFilter').value;
    const rid = document.getElementById('roleFilter').value;

    let list = users.slice();

    if (st !== '') {
      const wantDisabled = st === '1';
      list = list.filter(u => Boolean(u.is_disabled) === wantDisabled);
    }

    if (rid !== '') {
      const roleId = Number(rid);
      list = list.filter(u => (u.roles || []).some(r => r.id === roleId));
    }

    if (kw) {
      list = list.filter(u => {
        const s = `${u.account||''} ${u.name||''} ${u.email||''} ${u.cellphone||''}`.toLowerCase();
        return s.includes(kw);
      });
    }

    renderTable(list);
  }

  function resetFilters() {
    document.getElementById('kw').value = '';
    document.getElementById('statusFilter').value = '';
    document.getElementById('roleFilter').value = '';
    renderTable(users);
  }

  // ===== role modal =====
  async function openRoleModal(userId) {
    selectedUserId = userId;
    const res = await apiRequest('get', `/api/admin/users/${userId}/roles`);
    const current = new Set((res.roles || []).map(r => r.id));

    let html = '';
    for (const r of roles) {
      const checked = current.has(r.id) ? 'checked' : '';
      html += `
        <div class="form-check">
          <input class="form-check-input role-check" type="checkbox" value="${r.id}" id="role-${r.id}" ${checked}>
          <label class="form-check-label" for="role-${r.id}">${escapeHtml(r.name)} (${escapeHtml(r.code)})</label>
        </div>
      `;
    }
    document.getElementById('roleList').innerHTML = html;
    $('#roleModal').modal('show');
  }

  function checkAllRoles(on) {
    document.querySelectorAll('.role-check').forEach(x => x.checked = !!on);
  }

  async function saveRoles() {
    const checked = Array.from(document.querySelectorAll('.role-check'))
      .filter(x => x.checked)
      .map(x => Number(x.value));

    try {
      await apiRequest('post', `/api/admin/users/${selectedUserId}/roles`, { roleIds: checked });
      showSuccess('已更新角色');
      await loadData();
      $('#roleModal').modal('hide');
    } catch (e) {}
  }

  // ===== pwd modal =====
  function openPwdModal(userId) {
    clearModalMsg('pwdMsgBox');
    selectedUserId = userId;
    document.getElementById('newPwd').value = '';
    applySecurityConfigToUI();
    $('#pwdModal').modal('show');
  }

  async function resetPassword() {
    const btn = document.getElementById('btnResetPwd');
    btn.disabled = true;

    try {
      clearModalMsg('pwdMsgBox');

      const pwd = document.getElementById('newPwd').value || '';
      if (!pwd.trim()) {
        showPwdError('請輸入新密碼');
        return;
      }

      await apiRequest(
        'post',
        `/api/admin/users/${selectedUserId}/resetPassword`,
        { newPassword: pwd },
        { onError: (msg) => showPwdError(msg) }
      );

      showPwdSuccess('已重設密碼');
      await closeModalAfter('#pwdModal', 800); // ✅ 成功停留 0.8 秒後關閉
    } catch (e) {
    } finally {
      btn.disabled = false;
    }
  }

  // ===== disable =====
  function openDisableModal(userId) {
    disableTargetId = userId;
    document.getElementById('disableReason').value = '';
    $('#disableModal').modal('show');
  }

  async function confirmDisable() {
    const reason = document.getElementById('disableReason').value || '';
    try {
      await apiRequest('patch', `/api/admin/users/${disableTargetId}/disable`, { disabled:true, reason });
      $('#disableModal').modal('hide');
      await loadData();
      showSuccess('已停用');
    } catch (e) {}
  }

  async function toggleDisable(userId, disabled) {
    try {
      await apiRequest('patch', `/api/admin/users/${userId}/disable`, { disabled, reason: '' });
      await loadData();
      showSuccess(disabled ? '已停用' : '已啟用');
    } catch (e) {}
  }

  // ===== create =====
  function openCreateModal() {
    clearModalMsg('createMsgBox');

    document.getElementById('cAccount').value = '';
    document.getElementById('cPassword').value = '';
    document.getElementById('cName').value = '';
    document.getElementById('cCell').value = '';
    document.getElementById('cEmail').value = '';
    applySecurityConfigToUI();

    let html = '';
    for (const r of roles) {
      html += `
        <div class="form-check">
          <input class="form-check-input create-role-check" type="checkbox" value="${r.id}" id="crole-${r.id}">
          <label class="form-check-label" for="crole-${r.id}">${escapeHtml(r.name)} (${escapeHtml(r.code)})</label>
        </div>
      `;
    }
    document.getElementById('createRoleList').innerHTML = html;
    $('#createModal').modal('show');
  }

  function checkAllCreateRoles(on) {
    document.querySelectorAll('.create-role-check').forEach(x => x.checked = !!on);
  }

  async function createUser() {
    const btn = document.getElementById('btnCreateUser');
    btn.disabled = true;

    try {
      clearModalMsg('createMsgBox');

      const account = document.getElementById('cAccount').value.trim();
      const password = document.getElementById('cPassword').value || '';
      const name = document.getElementById('cName').value.trim();
      const cellphone = document.getElementById('cCell').value.trim();
      const email = document.getElementById('cEmail').value.trim();

      if (!account) { showCreateError('請輸入帳號'); return; }
      if (!password.trim()) { showCreateError('請輸入密碼'); return; }
      if (!cellphone) { showCreateError('手機為必填'); return; }
      if (!email) { showCreateError('Email 為必填'); return; }

      const roleIds = Array.from(document.querySelectorAll('.create-role-check'))
        .filter(x => x.checked)
        .map(x => Number(x.value));

      await apiRequest(
        'post',
        '/api/admin/users',
        { account, password, name, cellphone, email, roleIds },
        { onError: (msg) => showCreateError(msg) }
      );

      showCreateSuccess('建立成功');
      await closeModalAfter('#createModal', 800); // ✅ 成功停留 0.8 秒後關閉
      await loadData();
    } catch (e) {
    } finally {
      btn.disabled = false;
    }
  }

  // ===== detail + audit（✅ 可編輯）=====
  async function openDetailModal(userId) {
    try {
      detailTargetId = userId;
      auditTargetId = userId;
      auditOffset = 0;

      clearModalMsg('detailMsgBox');

      const [dRes, aRes] = await Promise.all([
        apiRequest('get', `/api/admin/users/${userId}`),
        apiRequest('get', `/api/admin/audit?target_user_id=${userId}&limit=${auditLimit}&offset=${auditOffset}`)
      ]);

      const u = dRes.user;
      const rs = dRes.roles || [];
      const roleText = rs.map(r => r.name).join(', ') || '—';

      // 填入可編輯欄位
      document.getElementById('dId').value = u.id ?? '';
      document.getElementById('dAccount').value = u.account ?? '';
      document.getElementById('dName').value = u.name ?? '';
      document.getElementById('dCell').value = u.cellphone ?? '';
      document.getElementById('dEmail').value = u.email ?? '';

      document.getElementById('dDates').value = `建立:${u.create_date || ''} / 更新:${u.update_date || ''}`;
      document.getElementById('dMetaText').innerText = `角色：${roleText}`;
      document.getElementById('dAuditText').innerHTML =
        (u.is_disabled ? `停用：是（${u.disabled_reason || ''}）` : `停用：否`) +
        '　｜　' +
        (u.password_reset_at ? `最後重設：${u.password_reset_at}` : `未曾由後台重設`);

      applySecurityConfigToUI();

      renderAuditRows(aRes.logs || [], true);
      $('#detailModal').modal('show');
    } catch (e) {
      console.error(e);
      showError('讀取詳情失敗（可能權限不足）');
    }
  }

  async function saveDetailProfile() {
    const btn = document.getElementById('btnSaveDetail');
    btn.disabled = true;

    try {
      clearModalMsg('detailMsgBox');

      const name = document.getElementById('dName').value.trim();
      const cellphone = document.getElementById('dCell').value.trim();
      const email = document.getElementById('dEmail').value.trim();

      if (!cellphone) { showDetailError('手機為必填'); return; }
      if (!email) { showDetailError('Email 為必填'); return; }

      await apiRequest(
        'patch',
        `/api/admin/users/${detailTargetId}/profile`,
        { name, cellphone, email },
        { onError: (msg) => showDetailError(msg) }
      );

      showDetailSuccess('已更新基本資料');

      // ✅ 同步更新列表
      await loadData();

      // ✅ 重新載入 detail 內容 + audit 第一頁（可選：你要最新紀錄就開）
      // 這裡採「只刷新 audit」更直覺
      auditOffset = 0;
      const aRes = await apiRequest('get', `/api/admin/audit?target_user_id=${detailTargetId}&limit=${auditLimit}&offset=${auditOffset}`);
      renderAuditRows(aRes.logs || [], true);

    } catch (e) {
    } finally {
      btn.disabled = false;
    }
  }

  function renderAuditRows(logs, replace) {
    let rows = '';
    for (const l of logs) {
      rows += `
        <tr>
          <td>${l.created_at || ''}</td>
          <td>${escapeHtml(l.actor_account || l.actor_user_id || '')}</td>
          <td>${escapeHtml(l.action || '')}</td>
          <td><pre class="audit-pre">${escapeHtml(formatDetail(l.detail_json))}</pre></td>
          <td>${escapeHtml(l.ip || '')}</td>
        </tr>
      `;
    }
    if (replace) {
      document.getElementById('auditRows').innerHTML = rows || `<tr><td colspan="5">無紀錄</td></tr>`;
    } else {
      const cur = document.getElementById('auditRows').innerHTML;
      if (cur.includes('無紀錄')) document.getElementById('auditRows').innerHTML = rows;
      else document.getElementById('auditRows').innerHTML = cur + rows;
    }

    document.getElementById('btnMoreAudit').style.display = logs.length < auditLimit ? 'none' : 'inline-block';
  }

  async function loadMoreAudit() {
    if (!auditTargetId) return;
    auditOffset += auditLimit;

    try {
      const aRes = await apiRequest('get', `/api/admin/audit?target_user_id=${auditTargetId}&limit=${auditLimit}&offset=${auditOffset}`);
      const logs = aRes.logs || [];
      renderAuditRows(logs, false);
    } catch (e) {}
  }

  $(document).ready(() => {
    clearMsg();
    Promise.all([loadSecurityConfig(), loadData()]).catch(e => {
      console.error(e);
      alert('權限不足或系統錯誤');
      location.href='/login';
    });
  });
</script>
