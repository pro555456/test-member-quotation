<%- include('./basic/auth_card.ejs', {
  authWrapClass: '',
  titleText: '註冊 Email 驗證',
  subtitleText: '系統正在驗證你註冊時使用的 Email，完成後會導回登入頁。',
  body: `
    <div id="subtitle" class="small-muted mb-3">請稍候，系統正在驗證中。</div>

    <div id="resendBox" class="mt-3" style="display:none;">
      <div class="auth-hr"></div>
      <h5 class="mb-2">重新寄送驗證信</h5>
      <div class="small-muted mb-3">
        如果驗證信已失效，或原本信件遺失，可使用 Email 或帳號重新申請。
      </div>

      <div class="form-group">
        <label for="rEmail">Email</label>
        <input id="rEmail" class="form-control" placeholder="name@example.com">
      </div>

      <div class="text-center small-muted my-2">或</div>

      <div class="form-group">
        <label for="rAccount">帳號</label>
        <input id="rAccount" class="form-control" placeholder="例如 user01 / wilson.tsai">
      </div>

      <div class="text-center">
        <button id="btnResend" class="btn btn-primary" onclick="doResend()">重新寄送</button>
      </div>

      <div class="small-muted mt-3">
        若帳號資料正確，系統會重新寄送驗證信到你的信箱。
      </div>
    </div>

    <div class="small-muted mt-3 text-center">
      若驗證失敗，請重新寄送驗證信後再試一次。
    </div>
  `
}) %>

<script>
  function showMsg(msg, type = 'danger', autoHideMs = 0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showSuccess(msg) { showMsg(msg, 'success', 900); }
  function showError(msg) { showMsg(msg, 'danger'); }
  function showInfo(msg) { showMsg(msg, 'info'); }

  function setSubtitle(text) {
    const el = document.getElementById('subtitle');
    if (el) el.innerText = text || '';
  }

  function getQuery(name) {
    const u = new URL(window.location.href);
    return u.searchParams.get(name);
  }

  function getApiErrorMessage(err, fallback = '操作失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function apiGet(url, params) {
    const res = await axios.get(url, { params });
    return res.data;
  }

  async function apiPost(url, data) {
    const res = await axios.post(url, data, {
      headers: { 'Content-Type': 'application/json' },
    });
    return res.data;
  }

  function showResendUI(on) {
    const box = document.getElementById('resendBox');
    if (box) box.style.display = on ? 'block' : 'none';
  }

  async function verify() {
    const token = getQuery('token');
    if (!token) {
      setSubtitle('缺少驗證 token，無法完成註冊驗證。');
      showError('缺少驗證 token');
      showResendUI(true);
      return;
    }

    try {
      setSubtitle('系統正在驗證註冊 Email，請稍候。');
      showInfo('驗證中…');

      const data = await apiGet('/api/auth/verify-email', { token });

      showSuccess(data?.message || '驗證成功');
      setSubtitle('Email 驗證成功，即將導回登入頁。');

      setTimeout(() => {
        window.location.assign('/login?verified=1');
      }, 900);
    } catch (error) {
      console.error(error);
      const msg = getApiErrorMessage(error, '驗證失敗');
      setSubtitle('Email 驗證失敗。');
      showError(msg);
      showResendUI(true);
    }
  }

  async function doResend() {
    const btn = document.getElementById('btnResend');
    btn.disabled = true;

    try {
      const email = (document.getElementById('rEmail').value || '').trim();
      const account = (document.getElementById('rAccount').value || '').trim();

      if (!email && !account) {
        showError('請輸入 Email 或帳號');
        return;
      }

      setSubtitle('重新寄送驗證信中…');
      showInfo('寄送中…');

      const payload = {};
      if (email) payload.email = email;
      if (!email && account) payload.account = account;

      const data = await apiPost('/api/auth/verify-email/resend', payload);

      showSuccess(data?.message || '驗證信已重新寄送');
      setSubtitle('請檢查信箱，並使用最新驗證信完成註冊。');
    } catch (error) {
      console.error(error);
      const msg = getApiErrorMessage(error, '重新寄送失敗');
      showError(msg);
      setSubtitle('重新寄送驗證信失敗。');
    } finally {
      btn.disabled = false;
    }
  }

  $(document).ready(() => verify());
</script>
