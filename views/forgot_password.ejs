<!-- 2) views/forgot_password.ejs -->
<%- include('./basic/auth_card.ejs', {
  authWrapClass: 'auth-wrap-md',
  titleText: '忘記密碼',
  subtitleText: '請輸入註冊時的 Email 或帳號，系統會寄送重設密碼連結',
  body: `
    <div class="form-group">
      <label for="email">Email（擇一）</label>
      <input id="email" class="form-control" placeholder="name@example.com">
    </div>

    <div class="text-center small-muted my-2">或</div>

    <div class="form-group">
      <label for="account">帳號（擇一）</label>
      <input id="account" class="form-control" placeholder="例：user01 / wilson.tsai">
    </div>

    <div class="text-center mb-3">
      <span class="small-muted">想起密碼了？</span>
      <a href="/login" class="ml-1">返回登入</a>
    </div>

    <div class="text-center">
      <button id="btnSend" type="button" onclick="sendResetMail()" class="btn btn-danger mr-2">寄送重設連結</button>
      <button type="button" class="btn btn-outline-secondary" onclick="resetForm()">重填</button>
    </div>
  `
}) %>

<script>
  function showMsg(msg, type='danger', autoHideMs=0) {
    const box = document.getElementById('msgBox');
    box.style.display = 'block';
    box.classList.remove('alert-danger', 'alert-success', 'alert-warning', 'alert-info');
    box.classList.add('alert-' + type);
    box.innerText = msg || '';
    box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    if (autoHideMs > 0) {
      setTimeout(() => {
        box.style.display = 'none';
        box.innerText = '';
      }, autoHideMs);
    }
  }

  function showError(msg) { showMsg(msg, 'danger'); }
  function showSuccess(msg) { showMsg(msg, 'success', 1200); }
  function showInfo(msg) { showMsg(msg, 'info'); }

  function clearMsg() {
    const box = document.getElementById('msgBox');
    box.style.display = 'none';
    box.innerText = '';
  }

  function getApiErrorMessage(err, fallback='操作失敗') {
    const data = err?.response?.data;
    return data?.message || err?.message || fallback;
  }

  async function apiRequest(method, url, data) {
    try {
      const res = await axios({ method, url, data });
      return res.data;
    } catch (err) {
      const msg = getApiErrorMessage(err);
      console.error('[API ERROR]', { method, url, msg, data, err, response: err?.response?.data });
      showError(msg);
      throw err;
    }
  }

  function resetForm() {
    document.getElementById('email').value = '';
    document.getElementById('account').value = '';
    clearMsg();
  }

  async function sendResetMail() {
    const btn = document.getElementById('btnSend');
    btn.disabled = true;
    clearMsg();

    try {
      const email = (document.getElementById('email').value || '').trim();
      const account = (document.getElementById('account').value || '').trim();

      if (!email && !account) {
        showError('請輸入 Email 或帳號');
        return;
      }

      showInfo('寄送中…');

      const payload = {};
      if (email) payload.email = email;
      if (!email && account) payload.account = account;

      const data = await apiRequest('post', '/api/auth/forgot-password', payload);
      showSuccess(data?.message || '若帳號存在，系統將寄出重設密碼連結');
    } catch (e) {
    } finally {
      btn.disabled = false;
    }
  }

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') {
      const active = document.activeElement;
      if (active && (active.id === 'email' || active.id === 'account')) {
        e.preventDefault();
        sendResetMail();
      }
    }
  });
</script>